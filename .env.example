# Copy this file to .env.local and fill in your real Supabase project values.
# Using placeholder/example values will cause "Invalid API key" errors on
# signup, login, and the /apply flow.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used by /api/ocr/scoreboard (Gemini scoreboard parsing)
GOOGLE_API_KEY=your-google-ai-studio-api-key

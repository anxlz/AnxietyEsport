# Copy this file to .env.local and fill in your real Supabase project values.
# Using placeholder/example values will cause "Invalid API key" errors on
# signup, login, and the /apply flow.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used by /api/ocr/scoreboard — Gemini 2.5 Flash (primary OCR provider)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-studio-api-key

# Used by /api/ocr/scoreboard — Groq Llama vision (fallback OCR provider)
# Get from: https://console.groq.com/keys
# If omitted, the route will only use Gemini with no fallback.
GROQ_API_KEY=your-groq-api-key

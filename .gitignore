# ============================================================================
# Anxiety Esports — .gitignore
# Next.js 15 + Supabase + Node.js
# ============================================================================

# ---- Environment variables (NEVER commit these) ----------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ---- Next.js ---------------------------------------------------------------
.next/
out/
build/

# ---- Node ------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- TypeScript ------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# ---- OS / Editor -----------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- Supabase --------------------------------------------------------------
# Local Supabase dev stack (if you ever run `supabase start` locally)
.supabase/

# ---- Misc ------------------------------------------------------------------
*.log
*.pem
.vercel
.turbo
